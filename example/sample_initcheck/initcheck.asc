/* !
 * \file initcheck.asc
 * \brief 算子未初始化检测样例，演示 mssanitizer 对算子读取未初始化内存异常的检测和定位
 */
#include "acl/acl.h"
#include "kernel_operator.h"

class UninitReadDemo {
public:
    __aicore__ inline UninitReadDemo() = default;
    __aicore__ inline void Init(GM_ADDR buf)
    {
        srcGlobal.SetGlobalBuffer((__gm__ uint8_t*)buf, bufSize);
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAlloc;
        AscendC::LocalTensor<uint8_t> localBuf = ubAlloc.Alloc<uint8_t, bufSize>();

        // 从 Global Memory 读取数据，但 main() 中有意未初始化该内存
        AscendC::DataCopy(localBuf, srcGlobal, bufSize);
    }

private:
    constexpr static uint32_t bufSize = 256;
    AscendC::GlobalTensor<uint8_t> srcGlobal;
};

__global__ __vector__ void uninit_read_demo(GM_ADDR buf)
{
    AscendC::InitSocState();
    UninitReadDemo op;
    op.Init(buf);
    op.Process();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t bufSize = 256;
    size_t bufBytes = bufSize * sizeof(uint8_t);

    aclInit(nullptr);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);

    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* devBuf = nullptr;
    aclrtMalloc((void**)&devBuf, bufBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    // 有意不对 devBuf 做初始化，算子内读取将触发未初始化告警

    uninit_read_demo<<<1, nullptr, stream>>>(devBuf);
    aclrtSynchronizeStream(stream);

    aclrtFree(devBuf);
    aclrtDestroyStream(stream);

    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
