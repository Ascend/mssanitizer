/* !
 * \file memcheck.asc
 * \brief 算子内存越界检测样例，演示 mssanitizer 对算子 UB 缓冲区越界写入的检测和定位
 */
#include "acl/acl.h"
#include "kernel_operator.h"

class BoundsWriteDemo {
public:
    __aicore__ inline BoundsWriteDemo() = default;
    __aicore__ inline void Init(GM_ADDR buf)
    {
        srcGlobal.SetGlobalBuffer((__gm__ float*)buf, elemCnt);
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAlloc;

        // UB 只分配了 allocCnt 个 float 的空间，
        // 但 DataCopy 搬运 elemCnt 个元素（elemCnt > allocCnt），越界写入
        AscendC::LocalTensor<float> localBuf = ubAlloc.Alloc<float, allocCnt>();
        AscendC::DataCopy(localBuf, srcGlobal, elemCnt);
    }

private:
    constexpr static uint32_t elemCnt = 256;   // DataCopy 搬运量
    constexpr static uint32_t allocCnt = 64;   // UB 实际分配量（不足，导致越界）
    AscendC::GlobalTensor<float> srcGlobal;
};

__global__ __vector__ void bounds_write_demo(GM_ADDR buf)
{
    AscendC::InitSocState();
    BoundsWriteDemo op;
    op.Init(buf);
    op.Process();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t elemCnt = 256;
    size_t bufBytes = elemCnt * sizeof(float);

    aclInit(nullptr);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);

    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* devBuf = nullptr;
    aclrtMalloc((void**)&devBuf, bufBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemset(devBuf, bufBytes, 0, bufBytes);

    bounds_write_demo<<<1, nullptr, stream>>>(devBuf);
    aclrtSynchronizeStream(stream);

    aclrtFree(devBuf);
    aclrtDestroyStream(stream);

    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
