/* !
 * \file racecheck.asc
 * \brief 算子数据竞争检测样例，演示 mssanitizer 对算子跨流水线 RAW 数据竞争的检测和定位
 */
#include "acl/acl.h"
#include "kernel_operator.h"

class RawHazardDemo {
public:
    __aicore__ inline RawHazardDemo() = default;
    __aicore__ inline void Init(GM_ADDR buf)
    {
        gmBuf.SetGlobalBuffer((__gm__ float*)buf, elemCnt);
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAlloc;
        AscendC::LocalTensor<float> localBuf = ubAlloc.Alloc<float, elemCnt>();

        // V 流水写入 Global Memory 后，MTE2 流水立即读取同一地址，
        // 缺少 SetFlag/WaitFlag 同步保护，构成 RAW 数据竞争
        uint32_t blockIdx = AscendC::GetBlockIdx();
        gmBuf.SetValue(blockIdx, (float)100.0f);       // V pipe: 写入
        AscendC::DataCopy(localBuf, gmBuf, elemCnt);   // MTE2 pipe: 读取（缺同步！）
    }

private:
    constexpr static uint32_t elemCnt = 256;
    AscendC::GlobalTensor<float> gmBuf;
};

__global__ __vector__ void raw_hazard_demo(GM_ADDR buf)
{
    AscendC::InitSocState();
    RawHazardDemo op;
    op.Init(buf);
    op.Process();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t elemCnt = 256;
    size_t bufBytes = elemCnt * sizeof(float);

    aclInit(nullptr);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);

    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* devBuf = nullptr;
    aclrtMalloc((void**)&devBuf, bufBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemset(devBuf, bufBytes, 0, bufBytes);

    // 启动 2 个 block，构造跨 block 数据竞争场景
    raw_hazard_demo<<<2, nullptr, stream>>>(devBuf);
    aclrtSynchronizeStream(stream);

    aclrtFree(devBuf);
    aclrtDestroyStream(stream);

    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
