/* !
 * \file synccheck.asc
 * \brief 算子同步检测样例，演示 mssanitizer 对算子同步异常的检测和定位
 */
#include "acl/acl.h"
#include "kernel_operator.h"

class DataMover {
public:
    __aicore__ inline DataMover() = default;
    __aicore__ inline void Init(GM_ADDR src, GM_ADDR dst)
    {
        srcGlobal.SetGlobalBuffer((__gm__ uint8_t*)src, bufSize);
        dstGlobal.SetGlobalBuffer((__gm__ uint8_t*)dst, bufSize);
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAlloc;
        AscendC::LocalTensor<uint8_t> localBuf = ubAlloc.Alloc<uint8_t, bufSize>();

        // 从 Global Memory 搬运到 Local Memory
        AscendC::DataCopy(localBuf, srcGlobal, bufSize);

        // 孤立 SetFlag，缺少对应 WaitFlag，触发同步异常
        AscendC::SetFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID0);

        // 从 Local Memory 搬运回 Global Memory
        AscendC::DataCopy(dstGlobal, localBuf, bufSize);
    }

private:
    constexpr static uint32_t bufSize = 256;
    AscendC::GlobalTensor<uint8_t> srcGlobal;
    AscendC::GlobalTensor<uint8_t> dstGlobal;
};

__global__ __vector__ void copy_demo(GM_ADDR src, GM_ADDR dst)
{
    AscendC::InitSocState();
    DataMover op;
    op.Init(src, dst);
    op.Process();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t bufSize = 256;
    size_t bufBytes = bufSize * sizeof(uint8_t);

    aclInit(nullptr);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);

    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* devSrc = nullptr;
    uint8_t* devDst = nullptr;

    aclrtMalloc((void**)&devSrc, bufBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&devDst, bufBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    // 初始化源缓冲区，避免未初始化读取（initcheck）干扰 synccheck 检测结果
    aclrtMemset(devSrc, bufBytes, 0, bufBytes);

    copy_demo<<<1, nullptr, stream>>>(devSrc, devDst);
    aclrtSynchronizeStream(stream);

    aclrtFree(devSrc);
    aclrtFree(devDst);

    aclrtDestroyStream(stream);

    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
